# Secrets
secrets/*
!secrets/README.md
!secrets/.gitkeep
*.env
*.env.local
.env

# Authelia runtime files (created by container at runtime)
authelia/db.sqlite3
authelia/notifications.txt
authelia/users.yml
authelia/*.log

# Postgres / backup volumes (host-mounted)
backups/
pgdata/

# Legacy data staged for M5 import — personal data, never committed
imports/

# Bun / Node
node_modules/
services/*/node_modules/
*.log

# Claude Code per-machine permission grants
.claude/settings.local.json

# QA browser profile (local Playwright persistent context — has cookies)
.qa-profile/
.qa-profile-show/

# Bun root lockfile (services have their own)
bun.lock

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
.gstack/
